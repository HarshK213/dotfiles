{
    "position": "top", 
    "layer": "top",
    "height": 20,
    "width": 1920,
    "spacing": 0,

    "include":["~/dotfiles/.config/waybar/modules.json"],


    "modules-left": [
        "custom/updates",
        "wlr/taskbar",
        "hyprland/window"
    ],
    "modules-center": [
         "clock#time",
         "clock#date",
         "hyprland/workspaces"
    ],
    "modules-right": [
        "custom/notification",
        "custom/power_mode",
        "pulseaudio",
        "group/connection",
        "group/hardware",
        "battery"
    ],

    "group/hardware":{
        "orientation":"horizontal",
        "modules":[
            "cpu",
            "memory"
        ]
    },

    "group/connection":{
        "orientation":"horizontal",
        "modules":[
            "network",
            "bluetooth"
        ]
    }
}
